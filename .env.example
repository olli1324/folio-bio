# --- Featherless ----------------------------------------------------------
# OpenAI-compatible API. Base URL is https://api.featherless.ai/v1
# Generate a key under account settings -> API Keys after subscribing to
# Feather Premium (free for the hackathon with code LABLABMILAN).
FEATHERLESS_API_KEY=

# Model routing. Small/fast model handles per-paper extraction (high volume,
# 1 concurrency slot each). Strong model handles the single synthesis call.
# Both IDs are from the Featherless catalogue - verify they resolve there.
# Mistral-Nemo-Instruct-2407 is a 12B model with 32K context (vs 4K on
# Mistral-7B-v0.3), which leaves room for long structured abstracts.
EXTRACT_MODEL=mistralai/Mistral-Nemo-Instruct-2407
SYNTHESIS_MODEL=deepseek-ai/DeepSeek-V3.2

# Feather Premium gives 4 concurrent connection slots. A 7B-15B model costs
# 1 slot, so 4 extraction calls can run at once. Keep this at 4 unless the
# extraction model is larger.
FEATHERLESS_CONCURRENCY=4

# --- PubMed / NCBI E-utilities --------------------------------------------
# Optional but recommended: a free NCBI key raises the rate limit from
# 3 to 10 requests/second. https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
NCBI_EMAIL=oliver.hole.ekelund@hotmail.no

# --- Pipeline tuning -------------------------------------------------------
# Upper bound on papers pulled per query. Keeps a run bounded in time and
# within the synthesis model's context window.
MAX_PAPERS=25

# --- Supabase (optional, only needed for briefing history) ----------------
# The engine and the CLI run without these. The FastAPI web app uses them
# to persist briefings so users can revisit / share past runs. SUPABASE_URL
# is the project URL; SUPABASE_SECRET_KEY is the server-side service-role
# key (starts with `sb_secret_`). Never expose the secret key to a browser.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
